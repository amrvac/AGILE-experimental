 &filelist
   base_filename    = 'output/TRML'
   saveprim         = T
 /

 &savelist
   itsave(1,1)      = 0
   itsave(1,2)      = 0
   itsave(1,3)      = 0
   ditsave_log      = 100
!  dtsave_dat       = 2.57d-1  !     t_sh/unit_time
   dtsave_dat       = 6.425d-2 ! 1/4 t_sh/unit_time
   nslices          = 1
   slicedir(1)      = 2
   slicecoord(1)    = +5d-1
 /

 &stoplist
!  time_max         = 7.74d0  ! 30 t_sh/unit_time
   time_max         = 5.14d0  ! 20 t_sh/unit_time
!  time_max         = 2.580d0 ! 10 t_sh/unit_time
!  time_max         = 2.056d0 !  8 t_sh/unit_time
!  time_max         = 2.58d-1 !  1 t_sh/unit_time
!  it_max           = 1
 /

 &methodlist
   time_stepper    = 'threestep'
   flux_scheme     = 20*'hllc'
   limiter         = 20*'vanleer'
   small_values_method = 'ignore'
   phys                = 'hd'
 /

 &boundlist
   specialboundary = T
   typeboundary_min1 = 5*'periodic'
   typeboundary_max1 = 5*'periodic'
   typeboundary_min2 = 5*'periodic'
   typeboundary_max2 = 5*'periodic'
   typeboundary_min3 = 5*'special'
   typeboundary_max3 = 5*'special'
 /

 &meshlist
   refine_max_level   = 2
   itfixgrid          = 0
   refine_criterion   = 1
   refine_usr         = T
   max_blocks         = 1800
   block_nx1          = 32
   block_nx2          = 32
   block_nx3          = 32
   domain_nx1         = 128
   domain_nx2         = 128
   domain_nx3         = 1024
   xprobmin1       = +0d0
   xprobmax1       = +1d0
   xprobmin2       = +0d0
   xprobmax2       = +1d0
   xprobmin3       = -4d0
   xprobmax3       = +4d0
 /

 &paramlist
   slowsteps        = 10
   courantpar       = 0.7d0
   typecourant      = 'maxsum'
 /

 &hd_list
   He_abundance = 0d0
   hd_radiative_cooling = T
 /

 &rc_list
    ncool=4000
    coolcurve='custom'
    coolmethod='exact'
    Tfix=.true.
 /

 &usr_list
   seed      = 20360812 ! dimensionless
   xi        = 1d1      ! dimensionless
   chi       = 1d2      ! dimensionless
   mach_H    = 3d-1     ! dimensionless
   rho_C     = 1d-20    ! CGS
   L_x       = 2.03d16  ! CGS
   v_sh      = 7.04d6   ! CGS
   v_off     = 0d0      ! CGS
   v_per(2)  = 7.04d4   ! CGS
   v_per(3)  = 7.04d4   ! CGS
   z0        = -1d0     ! code units
   d_z       = 5d-2     ! code units
   sig_z     = 2d-1     ! code units
   f_til(2)  = 2d-2     ! dimensionless
   f_til(3)  = 2d-2     ! dimensionless
   mode_root = 1        ! dimensionless
   n_modes   = 10       ! dimensionless
   refine_z(1) = -1d0   ! code units
   refine_z(2) = +1d0   ! code units
 /
